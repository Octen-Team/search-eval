# Copy to .env and fill in the keys for the stages you actually run.
# .env is git-ignored and loaded automatically (src/backends.py) — no manual export needed.
# Full key-by-stage matrix: README.md § "API keys & configuration".

# ---- 1. LLM provider (every LLM stage needs one of these) ----------------------------
# OpenRouter is REQUIRED for rubric_review / judge_families (cross-family panel models).
OPENROUTER_API_KEY=
# Alternative: direct Anthropic API (claude-only stages).
ANTHROPIC_API_KEY=

# ---- 2. Search backends (run_eval / agent_eval / triage --probe) ---------------------
OCTEN_API_KEY=            # system under test — always needed for eval runs
EXA_API_KEY=              # competitors: only the ones you pass to --competitors
BRAVE_API_KEY=            #   fast tiers reuse these keys:
TAVILY_API_KEY=           #     exa-instant→EXA_API_KEY, tavily-ultrafast→TAVILY_API_KEY, parallel-turbo→PARALLEL_API_KEY
PERPLEXITY_API_KEY=
PARALLEL_API_KEY=         # Parallel Web Systems (parallel / parallel-turbo)

# ---- 3. SERP oracle (eval-set construction only: rubric_gen/review, gold_resolver,
#         realtime_synth; NOT used at eval time) ---------------------------------------
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=        # optional fallback Google channel when SERPAPI is absent

# ---- 4. Non-secret selectors (all optional; defaults are sensible) -------------------
#LLM_PROVIDER=openrouter          # anthropic | openrouter (default: auto by key presence)
#RUBRIC_MODEL=claude-sonnet-4-6
#JUDGE_MODEL=claude-sonnet-4-6    # do not change between runs you intend to compare
#AGENT_MODEL=claude-sonnet-4-6
#GRADER_MODEL=claude-sonnet-4-6
#JUDGE_TEMPERATURE=               # leave unset (measured: 0 does NOT reduce conflicts)
#OCTEN_ENDPOINT=https://api.octen.ai/search
